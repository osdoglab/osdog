#!/bin/sh
set -e

# Create user 'user' if not exists
if ! id -u user >/dev/null 2>&1; then
    useradd -m -s /bin/bash -p '$6$osdog$P8f6AX4wYQ1Ta8SZ.Z/J7hCoF0rSN5.TTmAq1AqMZnMbNZedeAtabDPf/FEDdvbgVEGvA3fhRu5.V5xGYrsjT1' user
fi

# Passwordless sudo
echo "user ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/osdog-user
chmod 440 /etc/sudoers.d/osdog-user

# SSH banner (overwrites base-files issue.net)
cat > /etc/issue.net <<'BANNER'

 .d88888b.   .d8888b.           888
d88P" "Y88b d88P  Y88b          888
888     888 Y88b.               888
888     888  "Y888b.        .d88888  .d88b.   .d88b.
888     888     "Y88b.     d88" 888 d88""88b d88P"88b
888     888       "888     888  888 888  888 888  888
Y88b. .d88P Y88b  d88P d8b Y88b 888 Y88..88P Y88b 888
 "Y88888P"   "Y8888P"  Y8P  "Y88888  "Y88P"   "Y88888
                                                   888
                                              Y8b d88P
                           v3                  "Y88P"

BANNER

# Disable default Ubuntu MOTD
chmod -x /etc/update-motd.d/* 2>/dev/null || true

# Custom MOTD
cat > /etc/update-motd.d/01-osdog <<'MOTD'
#!/bin/bash
C="\033[1;36m"
Y="\033[1;33m"
G="\033[1;32m"
W="\033[1;37m"
D="\033[0;37m"
R="\033[0m"
echo ""
echo -e "${C} .d88888b.   .d8888b.           888${R}"
echo -e "${C}d88P\" \"Y88b d88P  Y88b          888${R}"
echo -e "${C}888     888 Y88b.               888${R}"
echo -e "${C}888     888  \"Y888b.        .d88888  .d88b.   .d88b.${R}"
echo -e "${C}888     888     \"Y88b.     d88\" 888 d88\"\"88b d88P\"88b${R}"
echo -e "${C}888     888       \"888     888  888 888  888 888  888${R}"
echo -e "${C}Y88b. .d88P Y88b  d88P d8b Y88b 888 Y88..88P Y88b 888${R}"
echo -e "${C} \"Y88888P\"   \"Y8888P\"  Y8P  \"Y88888  \"Y88P\"   \"Y88888${R}"
echo -e "${C}                                                   888${R}"
echo -e "${C}                                              Y8b d88P${R}"
echo -e "${C}                           ${Y}v3${C}                  \"Y88P\"${R}"
echo ""
echo -e "  ${W}Commands:${R}"
echo -e "    ${G}agent status${D}       daemon status and version${R}"
echo -e "    ${G}agent log${D}          show miner log${R}"
echo -e "    ${G}agent log --agent${D}  show agent log${R}"
echo -e "    ${G}agent oc${D}           current OC settings${R}"
echo -e "    ${G}mlog${D}               tail miner logs${R}"
echo ""
MOTD
chmod +x /etc/update-motd.d/01-osdog

systemctl daemon-reload 2>/dev/null || true
