#!/bin/bash
# ============================================================
# OS.Dog v3 — Network Disk Deploy v3.1
# Network Disk Deploy — write OS image to boot disk.
# ============================================================

export PATH=/bin:/sbin:/usr/bin:/usr/sbin:/usr/local/bin:/usr/local/sbin:$PATH
SCRIPT_PATH=$(cd "$(dirname "$0")" 2>/dev/null && pwd || pwd)
SCRIPT_NAME=$(basename "$0")
TMPDIR="/tmp/osdog"

# ---- Colors ----
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

# ---- CLI globals ----
OPT_YES=""
OPT_URL=""
OPT_RIG_ID=""
OPT_PASSWORD=""
OPT_SERVER=""

# ---- Runtime ----
DISK_NAME=""
IMAGE_FILE=""

die()  { echo -e "${RED}[FATAL]${NC} $*" >&2; exit 1; }
warn() { echo -e "${YELLOW}[WARN]${NC} $*"; }
info() { echo -e "${CYAN}[*]${NC} $*"; }
ok()   { echo -e "${GREEN}[OK]${NC} $*"; }

show_banner() {
    echo -e "${CYAN}"
    cat <<'ART'
 .d88888b.   .d8888b.           888
d88P" "Y88b d88P  Y88b          888
888     888 Y88b.               888
888     888  "Y888b.        .d88888  .d88b.   .d88b.
888     888     "Y88b.     d88" 888 d88""88b d88P"88b
888     888       "888     888  888 888  888 888  888
Y88b. .d88P Y88b  d88P d8b Y88b 888 Y88..88P Y88b 888
 "Y88888P"   "Y8888P"  Y8P  "Y88888  "Y88P"   "Y88888
                                                   888
                                              Y8b d88P
                                               "Y88P"
ART
    echo -e "${YELLOW}        Network Disk Deploy v3.1${NC}"
    echo ""
}

disk_part() {
    local disk="$1" num="$2"
    if [[ "$disk" == nvme* || "$disk" == mmcblk* ]]; then
        echo "${disk}p${num}"
    else
        echo "${disk}${num}"
    fi
}

detect_disk() {
    local root_spec root_part=""
    root_spec=$(tr ' ' '\n' < /proc/cmdline | grep -E '^root=' | tail -1 | sed 's/^root=//') || true

    if [[ "$root_spec" == UUID=* ]]; then
        root_part=$(blkid -U "${root_spec#UUID=}" 2>/dev/null) || true
    elif [[ "$root_spec" == LABEL=* ]]; then
        root_part=$(blkid -L "${root_spec#LABEL=}" 2>/dev/null) || true
    elif [[ "$root_spec" == /dev/* ]]; then
        root_part="$root_spec"
    fi
    [[ -z "$root_part" ]] && root_part=$(findmnt -n -o SOURCE / 2>/dev/null) || true
    [[ -z "$root_part" ]] && die "Cannot determine root partition"

    root_part="${root_part#/dev/}"
    if [[ "$root_part" == nvme* || "$root_part" == mmcblk* ]]; then
        DISK_NAME="${root_part%p[0-9]*}"
    else
        DISK_NAME=$(echo "$root_part" | sed 's/[0-9]*$//')
    fi

    local disk_size
    disk_size=$(awk -v disk="$DISK_NAME" '$4 == disk {printf "%.0f", $3/1024}' /proc/partitions)
    [[ -z "$disk_size" ]] && die "Cannot determine disk size"
    [[ "$disk_size" -lt 7300 ]] && die "Disk too small: ${disk_size} MB (need 8 GB)"

    info "Boot disk: /dev/${DISK_NAME} (${disk_size} MB)"
}

preserve_config() {
    mkdir -p "${TMPDIR}/saved-config"

    if [[ -n "$OPT_RIG_ID" && -n "$OPT_PASSWORD" ]]; then
        cat > "${TMPDIR}/saved-config/agent.yaml" <<YAML
server:
  url: "${OPT_SERVER:-wss://os.dog}"

rig:
  id: ${OPT_RIG_ID}
  password: "${OPT_PASSWORD}"

agent:
  stats_interval: 5
YAML
        info "Config from CLI (rig #${OPT_RIG_ID})"
        return
    fi

    if [[ -f /opt/osdog/config/agent.yaml ]]; then
        cp /opt/osdog/config/agent.yaml "${TMPDIR}/saved-config/agent.yaml"
        info "Preserved OS.Dog v3 config"
    elif [[ -f /dog/cfg/rig.cfg ]]; then
        source /dog/cfg/rig.cfg 2>/dev/null || true
        if [[ -n "${RIG_ID:-}" && -n "${PASSWD:-}" ]]; then
            cat > "${TMPDIR}/saved-config/agent.yaml" <<YAML
server:
  url: "${HOST:-wss://os.dog}"

rig:
  id: ${RIG_ID}
  password: "${PASSWD}"

agent:
  stats_interval: 5
YAML
            info "Preserved OS.Dog v2 config"
        fi
    else
        warn "No config found"
    fi
}

stop_services() {
    info "Stopping services..."

    echo 0 > /proc/sys/kernel/printk 2>/dev/null || true
    echo 1 > /proc/sys/kernel/sysrq 2>/dev/null || true

    swapoff -a 2>/dev/null || true
    [[ -c /dev/watchdog ]] && echo "V" > /dev/watchdog 2>/dev/null || true

    # OS-specific
    miner stop 2>/dev/null || true
    crontab -r 2>/dev/null || true
    for svc in agent hivex hive-watchdog hive hive-console avg_khs mining wd dogx; do
        systemctl stop "$svc" 2>/dev/null || true
    done
    screen -ls 2>/dev/null | grep -oP '^\s*\K[0-9]+' | xargs -r kill -9 2>/dev/null || true
    killall -9 Xorg xinit 2>/dev/null || true

    # Stop all non-essential services
    for svc in $(systemctl list-units -t socket --no-legend 2>/dev/null | awk '{print $1}' | grep -v -e ssh -e network -e ifup -e systemd-); do
        systemctl stop "$svc" > /dev/null 2>&1
    done
    for svc in $(systemctl list-units -t service --no-legend 2>/dev/null | awk '{print $1}' | grep -v -e ssh -e network -e ifup -e systemd- -e user-sessions); do
        systemctl stop "$svc" > /dev/null 2>&1
    done

    # Kill processes with open files on root
    local pid="1"
    while [[ -n "$pid" ]]; do
        pid=$(lsof / 2>/dev/null | grep -v ' \(mem\|txt\|rtd\|cwd\) ' | grep -v "$SCRIPT_NAME" | sed '2!d' | awk '{print $2}')
        [[ -z "$pid" ]] && continue
        local pname
        pname=$(lsof / 2>/dev/null | grep -v ' \(mem\|txt\|rtd\|cwd\) ' | grep -v "$SCRIPT_NAME" | sed '2!d' | awk '{print $1}')
        echo "  Kill $pname ($pid)"
        kill "$pid" 2>/dev/null || true
        sleep 1
    done
}

# ============================================================
# Phase 1: Prepare (runs on live system)
# ============================================================
prepare() {
    show_banner

    local mem
    mem=$(free -m | awk 'NR==2{print $2}')
    [[ $mem -lt 3600 ]] && die "Need 4 GB RAM (have ${mem} MB)"
    info "RAM: ${mem} MB"

    detect_disk

    echo ""
    echo -e "Image:  ${GREEN}${OPT_URL}${NC}"
    echo -e "Disk:   ${CYAN}/dev/${DISK_NAME}${NC}"
    echo ""

    if [[ "$OPT_YES" != "1" ]]; then
        echo -e "${RED}WARNING: ALL DATA on /dev/${DISK_NAME} WILL BE DESTROYED!${NC}"
        echo -n "Type 'yes' to continue: "
        local answer
        read -r answer
        [[ "$answer" != "yes" ]] && die "Aborted"
    fi

    # Tmpfs
    mkdir -p "$TMPDIR"
    mount -t tmpfs -o size=3500m none "$TMPDIR"

    # Preserve config
    preserve_config

    # Download image
    local filename
    filename=$(basename "$OPT_URL")
    IMAGE_FILE="$filename"

    info "Downloading ${filename}..."
    if [[ "$OPT_URL" == http* || "$OPT_URL" == ftp* ]]; then
        if command -v wget &>/dev/null; then
            wget -t 3 -T 60 --show-progress -O "${TMPDIR}/${filename}" "$OPT_URL" || die "Download failed"
        else
            curl -fL --progress-bar -o "${TMPDIR}/${filename}" "$OPT_URL" || die "Download failed"
        fi
    elif [[ -f "$OPT_URL" ]]; then
        cp -v "$OPT_URL" "${TMPDIR}/${filename}" || die "Copy failed"
    else
        die "Cannot get image: $OPT_URL"
    fi
    ok "Downloaded: $(du -m "${TMPDIR}/${filename}" | cut -f1) MB"

    # Verify
    if [[ "$filename" == *.xz ]]; then
        info "Verifying image..."
        xz -t "${TMPDIR}/${filename}" || die "Image corrupted"
        ok "Image OK"
    fi

    # Stop services
    stop_services

    # Remount all to RO
    for mnt in $(cat /proc/mounts | grep "$DISK_NAME" | awk '{print $2}'); do
        mount -n -o remount,ro "$mnt" > /dev/null 2>&1 || true
    done

    # Build temp root
    info "Building temporary root filesystem..."
    local R="$TMPDIR/root"
    mkdir -p "$R"/{proc,sys,run,dev,tmp,oldroot,usr/bin,usr/sbin,usr/lib,usr/share}

    # Copy actual directories (Ubuntu 24.04: /bin→/usr/bin, /lib→/usr/lib)
    cp -aR /usr/bin "$R/usr/" 2>/dev/null || true
    cp -aR /usr/sbin "$R/usr/" 2>/dev/null || true
    cp -aR /usr/lib/x86_64-linux-gnu "$R/usr/lib/" 2>/dev/null || true
    cp -aR /usr/lib/sudo "$R/usr/lib/" 2>/dev/null || true
    cp -aR /etc "$R/" 2>/dev/null || true

    # Handle merged-usr (Ubuntu 24.04+) and traditional layout
    if [[ -L /bin ]]; then
        # Merged: /bin→usr/bin, create same symlinks
        ln -sf usr/bin "$R/bin"
        ln -sf usr/sbin "$R/sbin"
        ln -sf usr/lib "$R/lib"
        cp -aR /usr/lib64 "$R/usr/" 2>/dev/null || true
        ln -sf usr/lib64 "$R/lib64"
    else
        # Traditional: copy real dirs
        cp -aR /bin "$R/" 2>/dev/null || true
        cp -aR /sbin "$R/" 2>/dev/null || true
        mkdir -p "$R/lib"
        cp -aR /lib/x86_64-linux-gnu "$R/lib/" 2>/dev/null || true
        cp -aR /lib64 "$R/" 2>/dev/null || true
    fi

    # Verify essential binaries got copied
    local missing=()
    for f in "$R/bin/bash" "$R/bin/dd"; do
        [[ -f "$f" ]] || missing+=("$f")
    done
    if [[ ${#missing[@]} -gt 0 ]]; then
        die "Failed to copy binaries to chroot: ${missing[*]}
  df tmpfs: $(df -h "$TMPDIR" 2>&1)
  Check RAM: tmpfs may be full."
    fi

    mount --bind /proc "$R/proc"
    mount --bind /sys "$R/sys"
    mount --bind /dev "$R/dev"

    # Copy script + data into chroot
    cp "$SCRIPT_PATH/$SCRIPT_NAME" "$R/$SCRIPT_NAME"
    chmod +x "$R/$SCRIPT_NAME"
    mv "${TMPDIR}/${filename}" "$R/${filename}"
    [[ -d "${TMPDIR}/saved-config" ]] && cp -a "${TMPDIR}/saved-config" "$R/saved-config"

    # Phase 2 config
    cat > "$R/replace.conf" <<CONF
DISK_NAME=${DISK_NAME}
IMAGE_FILE=${filename}
CONF

    ok "Chroot ready"

    # Preflight: verify chroot actually works before exec'ing into it.
    # "No such file or directory" from chroot usually means the dynamic
    # linker (ld-linux) or a library is missing, not bash itself.
    if ! chroot "$R" /bin/bash -c 'echo ok' &>/dev/null; then
        echo ""
        die "Chroot preflight failed. Diagnostics:
  bash:      $(ls -la "$R/bin/bash" 2>&1)
  ld-linux:  $(ls -la "$R/lib64/ld-linux-x86-64.so.2" 2>&1)
  ldd bash:  $(chroot "$R" ldd /bin/bash 2>&1 || true)
  df tmpfs:  $(df -h "$TMPDIR" 2>&1)"
    fi

    info "Entering chroot..."

    sync
    cd "$R"
    exec setsid chroot . /bin/bash "/$SCRIPT_NAME"
}

# ============================================================
# Phase 2: Write (runs inside tmpfs chroot)
# ============================================================
write() {
    cd /

    echo ""
    echo "========================================"
    echo " netdd phase 2: writing image to disk"
    echo " DISK: /dev/${DISK_NAME}"
    echo " IMAGE: ${IMAGE_FILE}"
    echo " DO NOT POWER OFF!"
    echo "========================================"
    echo ""

    # Prepare config partition image BEFORE sysrq-u.
    # Extract config partition from downloaded image, write agent.yaml via mcopy or loop mount.
    local cfg_ready=""
    local cfg_img="/tmp/cfg.img"
    if [[ -d /saved-config ]]; then
        echo "[netdd] Preparing config..."
        # Extract config partition from image (partition 1: sector 2048, 45056 sectors)
        if [[ "$IMAGE_FILE" == *.xz ]]; then
            xzcat "/${IMAGE_FILE}" | dd bs=512 skip=2048 count=45056 of="$cfg_img" 2>/dev/null
        else
            dd if="/${IMAGE_FILE}" bs=512 skip=2048 count=45056 of="$cfg_img" 2>/dev/null
        fi

        if command -v mcopy &>/dev/null; then
            # mtools: write directly to FAT image without mounting
            mcopy -o -i "$cfg_img" /saved-config/agent.yaml ::agent.yaml 2>/dev/null && cfg_ready=1
        fi
        if [[ -z "$cfg_ready" ]]; then
            # Fallback: loop mount
            mkdir -p /tmp/cfg
            if mount -o loop "$cfg_img" /tmp/cfg 2>/dev/null; then
                cp /saved-config/agent.yaml /tmp/cfg/agent.yaml 2>/dev/null && cfg_ready=1
                umount /tmp/cfg 2>/dev/null || true
            else
                echo "[netdd] WARNING: cannot mount config image (loop)"
            fi
        fi

        if [[ "$cfg_ready" == "1" ]]; then
            echo "[netdd] Config:"
            cat /saved-config/agent.yaml 2>/dev/null
            echo "[netdd] Config image prepared"
        fi
    fi

    # Nuclear flush: guarantee no dirty pages survive before dd.
    # Problem: ext4 journal thread (jbd2) keeps creating dirty pages in
    # partition device caches even after umount attempts from chroot.
    # If those stale dirty pages get flushed during/after dd (via memory
    # pressure or writeback), they overwrite freshly written image data.
    # Solution: sysrq-s syncs all filesystems, sysrq-u force-remounts
    # everything read-only (stops jbd2), then flush buffer caches.
    echo 1 > /proc/sys/kernel/sysrq 2>/dev/null || true
    echo s > /proc/sysrq-trigger 2>/dev/null || true
    sleep 1
    echo u > /proc/sysrq-trigger 2>/dev/null || true
    sleep 1

    for p in /dev/${DISK_NAME}[0-9]*; do
        umount "$p" 2>/dev/null || true
    done
    sync
    blockdev --flushbufs "/dev/${DISK_NAME}" 2>/dev/null || true
    for p in /dev/${DISK_NAME}[0-9]*; do
        blockdev --flushbufs "$p" 2>/dev/null || true
    done
    echo 3 > /proc/sys/vm/drop_caches 2>/dev/null || true

    # Disable kernel writeback daemon to prevent it from flushing any
    # dirty pages that might appear during dd (from partition device caches).
    echo 0 > /proc/sys/vm/dirty_writeback_centisecs 2>/dev/null || true
    echo 99999999 > /proc/sys/vm/dirty_expire_centisecs 2>/dev/null || true

    # Write image (oflag=direct bypasses page cache entirely)
    if [[ "$IMAGE_FILE" == *.xz ]]; then
        xzcat "/${IMAGE_FILE}" | dd of="/dev/${DISK_NAME}" bs=4M oflag=direct status=progress
    else
        dd if="/${IMAGE_FILE}" of="/dev/${DISK_NAME}" bs=4M oflag=direct status=progress
    fi

    echo ""
    echo "[netdd] Image written"

    # Re-read partition table
    partprobe "/dev/${DISK_NAME}" > /dev/null 2>&1
    sleep 1

    # Fix GPT backup header (image smaller than disk).
    # IMPORTANT: parted -l with piped "Fix" does NOT actually fix the GPT
    # (tested on both files and block devices). Only sgdisk -e works reliably.
    if command -v sgdisk &>/dev/null; then
        echo "[netdd] Fixing GPT with sgdisk..."
        sgdisk -e "/dev/${DISK_NAME}" > /dev/null 2>&1 || true
    elif command -v parted &>/dev/null; then
        echo "[netdd] Fixing GPT with parted..."
        echo "Fix" | parted -l "/dev/${DISK_NAME}" ---pretend-input-tty > /dev/null 2>&1 || true
    fi

    partprobe "/dev/${DISK_NAME}" > /dev/null 2>&1
    sleep 3

    # Fix stale superblock in partition page cache.
    # ext4 keeps superblock buffer referenced in /dev/sdXN page cache — drop_caches
    # can't free it. After dd to whole-disk via O_DIRECT, partition caches still have
    # old (pre-dd) superblock. Fix: read correct data from whole-disk (O_DIRECT) and
    # write directly to partition device (O_DIRECT), bypassing page cache entirely.
    # Do NOT use blockdev --flushbufs on partitions — it would flush ALL stale dirty
    # pages (including journal blocks from old OS), corrupting the new image.
    echo "[netdd] Fixing partition superblocks..."
    for part_dev in /dev/${DISK_NAME}[0-9]* /dev/${DISK_NAME}p[0-9]*; do
        [[ -b "$part_dev" ]] || continue
        local bname="${part_dev#/dev/}"
        local start_file="/sys/class/block/${bname}/start"
        [[ -r "$start_file" ]] || continue
        local start_sect
        start_sect=$(cat "$start_file")
        # Read first 4K from whole-disk at partition offset, write to partition device.
        # Both use O_DIRECT — data goes disk→disk, no page cache interaction.
        dd if="/dev/${DISK_NAME}" of="${part_dev}" \
            bs=4096 count=1 skip=$((start_sect / 8)) \
            iflag=direct oflag=direct 2>/dev/null || true
    done

    # Write prepared config partition to disk
    local cfg_part
    cfg_part=$(disk_part "$DISK_NAME" 1)
    if [[ "$cfg_ready" == "1" && -f "$cfg_img" && -b "/dev/${cfg_part}" ]]; then
        echo "[netdd] Writing config to /dev/${cfg_part}..."
        dd if="$cfg_img" of="/dev/${cfg_part}" bs=1M oflag=direct 2>/dev/null
        echo "[netdd] Config written OK"
    fi
    rm -f "$cfg_img" 2>/dev/null

    # Reboot
    echo ""
    echo "[netdd] Install complete!"
    echo "[netdd] Rebooting in 15 seconds..."

    # Only flush whole-disk device (for sgdisk GPT fix).
    # Do NOT flush partition devices — they may have stale dirty pages from
    # ext4 journal that would overwrite dd's data. Config partition was already
    # flushed after config write. Stale pages will be lost on sysrq-b reboot.
    blockdev --flushbufs "/dev/${DISK_NAME}" 2>/dev/null || true
    sleep 15

    echo 1 > /proc/sys/kernel/sysrq
    echo b > /proc/sysrq-trigger

    # Fallback
    sleep 5
    reboot -f 2>/dev/null || true
}

# ============================================================
# Entry point
# ============================================================
if [[ -f /replace.conf ]]; then
    source /replace.conf
    write
else
    # Parse args
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -y|--yes) OPT_YES=1 ;;
            --rig-id) shift; OPT_RIG_ID="$1" ;;
            --password) shift; OPT_PASSWORD="$1" ;;
            --server) shift; OPT_SERVER="$1" ;;
            -h|--help) show_banner; echo "Usage: netdd [-y] [--rig-id N] [--password STR] [--server URL] <image-url>"; exit 0 ;;
            *.iso.xz|*.iso|http*|ftp*) OPT_URL="$1" ;;
            *) die "Unknown: $1" ;;
        esac
        shift
    done

    [[ $EUID -ne 0 ]] && exec sudo "$0" "$@"
    [[ -z "$OPT_URL" ]] && { show_banner; echo "Usage: netdd [-y] [--rig-id N] [--password STR] [--server URL] <image-url>"; die "Image URL required"; }
    prepare
fi
