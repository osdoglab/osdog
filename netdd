#!/usr/bin/env bash
set -euo pipefail
# ============================================================
# OS.Dog v3 — Network Disk Deploy (netdd)
# Installs OS.Dog v3 image onto a mining rig's boot disk.
# Works on any Linux: OS.Dog v3/v1, HiveOS, RaveOS, MMPOS, ethOS, Ubuntu, etc.
#
# One-liner:
#   wget -qO /tmp/netdd https://os.dog/netdd && chmod +x /tmp/netdd && /tmp/netdd -y -l
# ============================================================

NETDD_VERSION="3.0"
TMPDIR="/tmp/osdog"
SCRIPT_PATH="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPT_NAME="$(basename "${BASH_SOURCE[0]}")"

# Prevent running from pipe
[[ "$(basename "$0")" == "bash" || "$(basename "$0")" == "sh" ]] && { echo "netdd does not work from pipe!"; exit 1; }

export PATH="/bin:/sbin:/usr/bin:/usr/sbin:/usr/local/bin:/usr/local/sbin:$PATH"

# ============================================================
# Colors
# ============================================================
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
PURPLE='\033[0;35m'
BOLD='\033[1m'
NC='\033[0m'

die()  { echo -e "${RED}[FATAL]${NC} $*" >&2; exit 1; }
warn() { echo -e "${YELLOW}[WARN]${NC} $*"; }
info() { echo -e "${CYAN}[*]${NC} $*"; }
ok()   { echo -e "${GREEN}[OK]${NC} $*"; }

# ============================================================
# CLI options (globals)
# ============================================================
OPT_YES=""
OPT_URL=""
OPT_RIG_ID=""
OPT_PASSWORD=""
OPT_SERVER=""
OPT_CONFIG=""
OPT_SSHPASS=""

# Runtime state
CURRENT_OS="linux"
DISK_NAME=""
DISK_SIZE_MB=""
IMAGE_URL=""
IMAGE_FILE=""

# ============================================================
# Helpers
# ============================================================
fetch_url() {
    local url="$1"
    if command -v wget &>/dev/null; then
        wget -qO- -T 20 "$url"
    elif command -v curl &>/dev/null; then
        curl -sLk --connect-timeout 20 "$url"
    else
        die "Neither wget nor curl available"
    fi
}

disk_part() {
    local disk="$1" num="$2"
    if [[ "$disk" == nvme* || "$disk" == mmcblk* ]]; then
        echo "${disk}p${num}"
    else
        echo "${disk}${num}"
    fi
}

